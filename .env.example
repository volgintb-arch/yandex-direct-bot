# =====================================================
# Yandex Direct Bot — environment configuration
# Copy to .env and fill values. Never commit .env.
# =====================================================

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://direct-bot.questlegends.ru/api/telegram/webhook
# Use polling in dev (no public URL needed): set to "true"
TELEGRAM_USE_POLLING=true

# === Bootstrap admin ===
# Your Telegram user ID — gets admin rights on first launch.
# Get it from @userinfobot
BOOTSTRAP_ADMIN_TG_ID=

# === Yandex Direct API ===
YANDEX_DIRECT_TOKEN=
YANDEX_DIRECT_CLIENT_LOGIN=Koms104b
YANDEX_DIRECT_API_URL=https://api.direct.yandex.com/json/v5

# === Yandex Wordstat ===
YANDEX_WORDSTAT_TOKEN=
YANDEX_WORDSTAT_API_URL=https://api.wordstat.yandex.net/v1

# === Yandex Metrika (для yclid → ad_id mapping) ===
YANDEX_METRIKA_TOKEN=
YANDEX_METRIKA_COUNTER_ID=

# === YandexGPT (Yandex AI Studio Foundation Models) ===
# 1) Get API key at https://aistudio.yandex.ru → API keys
# 2) Get folder ID at https://console.yandex.cloud → caталог "default"
# 3) Service account from API key needs `ai.languageModels.user` role
#    on BOTH the folder AND the cloud (set in console.yandex.cloud → Права доступа)
# 4) A billing account must be attached to the cloud (free trial works)
YANDEX_GPT_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# === QuestLegends OS CRM integration ===
CRM_BASE_URL=https://легендаобискателях.рф
CRM_INTEGRATION_API_KEY=

# === Database ===
# Local dev: postgresql://yandex_bot:secret@localhost:5432/yandex_bot
# Docker:    postgresql://yandex_bot:secret@host.docker.internal:5432/yandex_bot
DATABASE_URL=

# === Server ===
PORT=3004
NODE_ENV=development
LOG_LEVEL=info

# === Business profile (passed to AI as context) ===
BUSINESS_NAME=Квест-шоу Легенда об Искателях
BUSINESS_DESCRIPTION=Интерактивный квест с элементами шоу и тимбилдинга
BUSINESS_SITE=https://questlegends.ru
BUSINESS_AVG_CHECK=25000
BUSINESS_CITIES=Краснодар,Омск
