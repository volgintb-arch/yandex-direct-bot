// Yandex Direct Bot — database schema
// Use `prisma db push` to apply (no migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// AUTH & SESSIONS
// =====================================================

/// Whitelist of Telegram users allowed to use the bot.
/// First admin is bootstrapped via BOOTSTRAP_ADMIN_TG_ID env var.
model AuthorizedUser {
  id          Int       @id @default(autoincrement())
  telegramId  BigInt    @unique
  username    String?
  firstName   String?
  lastName    String?
  role        String    @default("user") // admin | user
  grantedBy   BigInt?   // telegramId of who granted
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime?

  @@index([role])
}

/// Per-chat session state machine.
model Session {
  chatId            BigInt   @id
  userId            BigInt
  state             String   @default("idle")
  // states: idle | awaiting_revision_text | awaiting_cpl | awaiting_image | awaiting_image_caption
  pendingApprovalId String?
  context           Json     @default("{}")
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@index([userId])
}

// =====================================================
// APPROVAL FLOW (drafts before applying to Direct)
// =====================================================

/// A draft campaign generated by AI, waiting for human approval.
model Approval {
  id     String @id @default(cuid())
  chatId BigInt

  status String @default("pending") // generating | pending | failed | approved | rejected | applied | expired
  errorMessage String? // populated when status='failed'

  // Campaign parameters
  campaignType  String // search | network | mixed
  geo           String
  regionId      Int    @default(0)
  dailyBudget   Int
  siteUrl       String
  targetCpl     Int?   // null = AI-suggested later
  cplSuggested  Boolean @default(false)

  // Bidding strategy (Direct)
  strategy     String  @default("WB_MAXIMUM_CLICKS") // WB_MAXIMUM_CLICKS | WB_MAXIMUM_CONVERSION_RATE | AVERAGE_CPC
  strategyBid  Int?    // for AVERAGE_CPC — desired avg CPC in rubles

  // AI variants
  variants            Json   // [{variant_id, title, strategy, draft: {...}}]
  selectedVariantId   String?

  // Image bank choices (for РСЯ)
  selectedImageHashes String[] @default([])

  // After applying — references in Yandex Direct
  yandexCampaignId BigInt?
  yandexAdgroupId  BigInt?
  yandexAdId       BigInt?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  appliedAt   DateTime?
  rejectedAt  DateTime?
  expiresAt   DateTime?

  @@index([chatId, status])
  @@index([status, createdAt])
}

// =====================================================
// MIRROR OF YANDEX DIRECT STATE
// =====================================================

model Campaign {
  yandexId       BigInt   @id
  name           String
  type           String   // search | network | mixed
  state          String   // ON | OFF | SUSPENDED | ARCHIVED | ENDED | CONVERTED
  status         String   // ACCEPTED | DRAFT | MODERATION | REJECTED
  city           String?
  regionId       Int?
  dailyBudget    Int?
  searchBidding  Json?
  networkBidding Json?
  targetCpl      Int?     // bot-tracked target for ROI evaluation
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  adgroups Adgroup[]

  @@index([city])
  @@index([type])
  @@index([state])
}

model Adgroup {
  yandexId   BigInt   @id
  campaignId BigInt
  name       String
  regionIds  Int[]    @default([])
  syncedAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [yandexId], onDelete: Cascade)
  ads      Ad[]

  @@index([campaignId])
}

model Ad {
  yandexId    BigInt   @id
  adgroupId   BigInt
  type        String   // text_ad | text_image_ad
  title1      String
  title2      String?
  text        String
  href        String
  imageHash   String?
  state       String
  status      String
  approvalId  String?  // link to draft that created this ad
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  adgroup Adgroup     @relation(fields: [adgroupId], references: [yandexId], onDelete: Cascade)
  metrics AdMetrics[]

  @@index([adgroupId])
  @@index([approvalId])
}

/// Daily ad performance + CRM enrichment for ROI learning.
model AdMetrics {
  id         Int      @id @default(autoincrement())
  adId       BigInt
  date       DateTime @db.Date

  // From Yandex
  impressions Int     @default(0)
  clicks      Int     @default(0)
  cost        Decimal @default(0) @db.Decimal(10, 2)
  ctr         Decimal @default(0) @db.Decimal(5, 2)
  avgCpc      Decimal @default(0) @db.Decimal(10, 2)

  // From CRM (enriched by sync-yclid job)
  leads       Int     @default(0)
  scheduled   Int     @default(0)
  completed   Int     @default(0)
  cancelled   Int     @default(0)
  revenue     Decimal @default(0) @db.Decimal(12, 2)

  // Computed
  cpl         Decimal? @db.Decimal(10, 2) // cost / leads
  roi         Decimal? @db.Decimal(8, 4)  // (revenue - cost) / cost

  syncedAt    DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [yandexId], onDelete: Cascade)

  @@unique([adId, date])
  @@index([date])
}

// =====================================================
// IMAGE BANK FOR РСЯ (Network) ADS
// =====================================================

/// Synced from Yandex Direct ImageAds + uploaded by users.
/// Each image gets an AI-generated description (Gemini Vision).
model YandexImage {
  hash        String   @id  // AdImageHash from Yandex
  name        String?
  format      String?  // JPEG | PNG | GIF
  width       Int?
  height      Int?
  url         String?  // Yandex CDN URL
  description String?  // Gemini Vision description
  tags        String[] @default([])
  uploadedBy  BigInt?  // telegramId if uploaded via bot
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([uploadedBy])
}

// =====================================================
// YCLID ↔ AD ↔ CRM LEAD LINKING (ROI learning core)
// =====================================================

/// Captured from Yandex Metrika Logs API:
///   yclid → which ad/keyword brought the visit.
/// Enriched from QL OS CRM:
///   yclid → did this visit become a lead/sale?
model YclidLink {
  yclid           String    @id
  adId            BigInt?
  campaignId      BigInt?
  adgroupId       BigInt?
  keyword         String?
  capturedAt      DateTime  @default(now())

  // CRM enrichment
  crmLeadId       String?
  crmLeadType     String?   // deal | game_lead
  isLead          Boolean   @default(false)
  isScheduled     Boolean   @default(false)
  isCompleted     Boolean   @default(false)
  isCancelled     Boolean   @default(false)
  saleAmount      Decimal?  @db.Decimal(12, 2)
  city            String?
  syncedFromCrmAt DateTime?

  @@index([adId])
  @@index([campaignId])
  @@index([syncedFromCrmAt])
}

// =====================================================
// AI MEMORY (knowledge base)
// =====================================================

/// Accumulated AI knowledge — never overwritten, only deactivated.
/// Used as context for campaign generation.
model KnowledgeEntry {
  id          Int      @id @default(autoincrement())
  type        String   // learned_rules | top_ad | insight | failure_pattern
  scope       String   @default("global") // search | network | global
  city        String?  // null = applies to all cities
  data        Json
  generatedBy String   // gemini-flash | gemini-pro | manual
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([type, scope, isActive])
  @@index([city])
}

// =====================================================
// REGION CACHE (Yandex Direct geo IDs)
// =====================================================

model RegionCache {
  yandexId  Int      @id
  name      String
  parentId  Int?
  type      String?  // 7=country, 5=city, 6=region
  cachedAt  DateTime @default(now())

  @@index([name])
  @@index([parentId])
}

// =====================================================
// API CALL LOG (debugging)
// =====================================================

model ApiCallLog {
  id           Int      @id @default(autoincrement())
  service      String   // yandex_direct | wordstat | metrika | gemini | crm
  endpoint     String
  status       Int?
  durationMs   Int?
  error        String?
  requestSize  Int?
  responseSize Int?
  createdAt    DateTime @default(now())

  @@index([service, createdAt])
  @@index([createdAt])
}
